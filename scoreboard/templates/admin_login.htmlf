<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#15171b">
  <link rel="shortcut icon" href="/images/favicon.png" type="image/png">
  <title>ЭТАЛОН CTF: Админ-панель</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <img class="auth-brand-owl" src="/images/etalon-owl.png" alt="Эталон">
      <div class="auth-brand-title">ЭТАЛОН CTF <em>2026</em></div>
    </div>

    <div class="admin-login-badge">Админ-панель</div>

    %s

    <form class="form-signin" action="/admin/auth" method="post">
      <label class="auth-label" for="token">Токен администратора</label>
      <input
        id="token"
        name="token"
        type="password"
        class="auth-input"
        placeholder="Токен администратора"
        required
        autofocus
        autocomplete="off"
        spellcheck="false"
      >
      <button class="btn btn-lg" type="submit">Войти</button>
    </form>
  </div>
</div>

</body>
</html>
